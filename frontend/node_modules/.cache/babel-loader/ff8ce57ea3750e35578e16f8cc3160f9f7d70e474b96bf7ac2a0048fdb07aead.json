{"ast":null,"code":"import{useEffect,useState}from\"react\";export const useCooldown=endTime=>{const[remaining,setRemaining]=useState(endTime-Math.floor(Date.now()/1000));useEffect(()=>{const interval=setInterval(()=>{const now=Math.floor(Date.now()/1000);setRemaining(Math.max(endTime-now,0));},1000);return()=>clearInterval(interval);},[endTime]);const formatted=`${Math.floor(remaining/3600)}h ${Math.floor(remaining%3600/60)}m ${remaining%60}s`;return{remaining,formatted};};","map":{"version":3,"names":["useEffect","useState","useCooldown","endTime","remaining","setRemaining","Math","floor","Date","now","interval","setInterval","max","clearInterval","formatted"],"sources":["/home/emperor-caesar/Faucet-Token/Faucet-Token/frontend/src/hooks/useCooldown.ts"],"sourcesContent":["import { useEffect, useState } from \"react\";\nimport dayjs from \"dayjs\";\n\nexport const useCooldown = (endTime: number) => {\n  const [remaining, setRemaining] = useState(endTime - Math.floor(Date.now() / 1000));\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      const now = Math.floor(Date.now() / 1000);\n      setRemaining(Math.max(endTime - now, 0));\n    }, 1000);\n\n    return () => clearInterval(interval);\n  }, [endTime]);\n\n  const formatted = `${Math.floor(remaining / 3600)}h ${Math.floor((remaining % 3600) / 60)}m ${remaining % 60}s`;\n  return { remaining, formatted };\n};"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAG3C,MAAO,MAAM,CAAAC,WAAW,CAAIC,OAAe,EAAK,CAC9C,KAAM,CAACC,SAAS,CAAEC,YAAY,CAAC,CAAGJ,QAAQ,CAACE,OAAO,CAAGG,IAAI,CAACC,KAAK,CAACC,IAAI,CAACC,GAAG,CAAC,CAAC,CAAG,IAAI,CAAC,CAAC,CAEnFT,SAAS,CAAC,IAAM,CACd,KAAM,CAAAU,QAAQ,CAAGC,WAAW,CAAC,IAAM,CACjC,KAAM,CAAAF,GAAG,CAAGH,IAAI,CAACC,KAAK,CAACC,IAAI,CAACC,GAAG,CAAC,CAAC,CAAG,IAAI,CAAC,CACzCJ,YAAY,CAACC,IAAI,CAACM,GAAG,CAACT,OAAO,CAAGM,GAAG,CAAE,CAAC,CAAC,CAAC,CAC1C,CAAC,CAAE,IAAI,CAAC,CAER,MAAO,IAAMI,aAAa,CAACH,QAAQ,CAAC,CACtC,CAAC,CAAE,CAACP,OAAO,CAAC,CAAC,CAEb,KAAM,CAAAW,SAAS,CAAG,GAAGR,IAAI,C